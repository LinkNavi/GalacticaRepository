[Package]
name = "airride"
version = "1.0.0"
description = "AirRide init system"
url = "https://github.com/LinkNavi/Galactica/releases/download/airride-1.0.0/airride-1.0.0.tar.gz"
category = "core"

[Script]
mkdir -p /sbin /usr/bin
cp airride /sbin/airride
cp airridectl /usr/bin/airridectl
chmod 755 /sbin/airride /usr/bin/airridectl
ln -sf airride /sbin/init
