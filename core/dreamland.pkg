[Package]
name = "dreamland"
version = "1.0.0"
description = "Dreamland package manager"
url = "https://github.com/LinkNavi/Galactica/releases/download/dreamland-1.0.0/dreamland-1.0.0.tar.gz"
category = "core"

[Script]
mkdir -p /usr/bin
cp dreamland /usr/bin/dreamland
chmod 755 /usr/bin/dreamland
ln -sf dreamland /usr/bin/dl
